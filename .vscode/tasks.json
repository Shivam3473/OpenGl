{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build OpenGL",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++17",
                "-I${workspaceFolder}/MyProject/include",
                "-L${workspaceFolder}/MyProject/lib",
                "${file}",
                "${workspaceFolder}/MyProject/src/glad.c",
                "-lglfw3dll",
                "-o",
                "${workspaceFolder}/MyProject/${fileBasenameNoExtension}.exe",
                "-I",
                "D:/IMPORTANT FOLDERS/CGS RND/OpenGl/MyProject/src/glm"
            ],
            "options": {
                "cwd": "${workspaceFolder}/MyProject"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}